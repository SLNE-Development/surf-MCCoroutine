+// surf start - calling-plugin dispatcher accessors on kotlinx Dispatchers
+/**
+ * Gets the dispatcher to perform edits on data that the global region owns, such as game rules, day time, weather, or to execute commands using the console command sender.
+ * If Folia is not loaded, this falls back to the bukkit minecraftDispatcher.
+ *
+ * Unlike [Plugin.globalRegionDispatcher] this accessor takes no [Plugin] receiver. The owning plugin is resolved automatically from the
+ * caller's class via [MethodHandles], which is why this is `inline` and only callable from Kotlin plugin code.
+ */
+@get:JvmSynthetic
+@Suppress("NOTHING_TO_INLINE")
+inline val Dispatchers.GlobalDispatcher: CoroutineDispatcher
+    get() = CallingPluginDispatchers.global(
+        MethodHandles.lookup().lookupClass()
+    )
+
+/**
+ * Gets the dispatcher to schedule tasks on the region that owns the given [entity].
+ * If Folia is not loaded, this falls back to the bukkit minecraftDispatcher.
+ *
+ * Unlike [Plugin.entityDispatcher] this accessor takes no [Plugin] receiver. The owning plugin is resolved automatically from the
+ * caller's class via [MethodHandles], which is why this is `inline` and only callable from Kotlin plugin code.
+ */
+@JvmSynthetic
+@Suppress("NOTHING_TO_INLINE")
+inline fun Dispatchers.forEntity(entity: Entity): CoroutineDispatcher {
+    return CallingPluginDispatchers.forEntity(
+        MethodHandles.lookup().lookupClass(),
+        entity
+    )
+}
+
+/**
+ * Gets the dispatcher to schedule tasks on the region identified by [world] and the chunk coordinates [chunkX]/[chunkZ].
+ * If Folia is not loaded, this falls back to the bukkit minecraftDispatcher.
+ *
+ * Unlike [Plugin.regionDispatcher] this accessor takes no [Plugin] receiver. The owning plugin is resolved automatically from the
+ * caller's class via [MethodHandles], which is why this is `inline` and only callable from Kotlin plugin code.
+ */
+@JvmSynthetic
+@Suppress("NOTHING_TO_INLINE")
+inline fun Dispatchers.forRegion(
+    world: World,
+    chunkX: Int,
+    chunkZ: Int
+): CoroutineDispatcher {
+    return CallingPluginDispatchers.forRegion(
+        MethodHandles.lookup().lookupClass(),
+        world,
+        chunkX,
+        chunkZ
+    )
+}
+
+/**
+ * Gets the dispatcher to schedule tasks on the region that owns the given [location].
+ * If Folia is not loaded, this falls back to the bukkit minecraftDispatcher.
+ *
+ * Unlike [Plugin.regionDispatcher] this accessor takes no [Plugin] receiver. The owning plugin is resolved automatically from the
+ * caller's class via [MethodHandles], which is why this is `inline` and only callable from Kotlin plugin code.
+ *
+ * @throws IllegalArgumentException if the [location] has no world.
+ */
+@JvmSynthetic
+@Suppress("NOTHING_TO_INLINE")
+inline fun Dispatchers.forRegion(location: Location): CoroutineDispatcher {
+    val world = requireNotNull(location.world) {
+        "Cannot create a region dispatcher for a location without a world."
+    }
+
+    return CallingPluginDispatchers.forRegion(
+        MethodHandles.lookup().lookupClass(),
+        world,
+        location.blockX shr 4,
+        location.blockZ shr 4
+    )
+}
+
+/**
+ * Gets the plugin main dispatcher. The main dispatcher consists of a single thread dedicated for your plugin.
+ *
+ * Unlike [Plugin.mainDispatcher] this accessor takes no [Plugin] receiver. The owning plugin is resolved automatically from the
+ * caller's class via [MethodHandles], which is why this is `inline` and only callable from Kotlin plugin code.
+ */
+@JvmSynthetic
+@Suppress("NOTHING_TO_INLINE")
+inline fun Dispatchers.forPlugin(): CoroutineDispatcher {
+    return CallingPluginDispatchers.forPlugin(
+        MethodHandles.lookup().lookupClass()
+    )
+}
+
+/**
+ * Internal support for the calling-plugin dispatcher accessors. Resolves and caches the owning [JavaPlugin] for a caller class.
+ */
+@PublishedApi
+internal object CallingPluginDispatchers {
+    private val pluginByCallerClass = object : ClassValue<JavaPlugin>() {
+        override fun computeValue(type: Class<*>): JavaPlugin {
+            return try {
+                JavaPlugin.getProvidingPlugin(type)
+            } catch (e: IllegalArgumentException) {
+                throw IllegalStateException(
+                    "Cannot resolve the calling plugin for class '${type.name}'. " +
+                            "This API must be called from plugin code and should not be called from Java.",
+                    e
+                )
+            }
+        }
+    }
+
+    fun forEntity(
+        callerClass: Class<*>,
+        entity: Entity
+    ): CoroutineDispatcher {
+        val plugin = pluginByCallerClass.get(callerClass)
+
+        return plugin.entityDispatcher(entity)
+    }
+
+    fun forRegion(
+        callerClass: Class<*>,
+        world: World,
+        chunkX: Int,
+        chunkZ: Int
+    ): CoroutineDispatcher {
+        val plugin = pluginByCallerClass.get(callerClass)
+
+        return plugin.regionDispatcher(world, chunkX, chunkZ)
+    }
+
+    fun forPlugin(callerClass: Class<*>): CoroutineDispatcher {
+        val plugin = pluginByCallerClass.get(callerClass)
+
+        return plugin.mainDispatcher
+    }
+
+    fun global(callerClass: Class<*>): CoroutineDispatcher {
+        val plugin = pluginByCallerClass.get(callerClass)
+
+        return plugin.globalRegionDispatcher
+    }
+}
+// surf end - calling-plugin dispatcher accessors on kotlinx Dispatchers
+
 /**
