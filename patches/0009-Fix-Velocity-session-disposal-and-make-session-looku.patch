From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: twisti <76837088+twisti-dev@users.noreply.github.com>
Date: Sat, 16 May 2026 17:34:19 +0200
Subject: [PATCH] Fix Velocity session disposal and make session lookup atomic

disable() looked up the session with the PluginContainer as key, but
sessions are stored under the plugin instance, so the session was
never found and never disposed. Remove it atomically under the correct
key instead.

getCoroutineSession() now uses a single map read instead of a
containsKey()/get() pair, and setupCoroutineSession() calls
containsKey() explicitly instead of the contains() operator alias.

diff --git a/mccoroutine-velocity-core/src/main/java/com/github/shynixn/mccoroutine/velocity/impl/MCCoroutineImpl.kt b/mccoroutine-velocity-core/src/main/java/com/github/shynixn/mccoroutine/velocity/impl/MCCoroutineImpl.kt
index 1811c3548b25d505ebba94df8e868251e3687f51..ec99a09991abc7f06e57816e4250e47316014351 100644
--- a/mccoroutine-velocity-core/src/main/java/com/github/shynixn/mccoroutine/velocity/impl/MCCoroutineImpl.kt
+++ b/mccoroutine-velocity-core/src/main/java/com/github/shynixn/mccoroutine/velocity/impl/MCCoroutineImpl.kt
@@ -5,6 +5,7 @@ import com.github.shynixn.mccoroutine.velocity.MCCoroutine
 import com.github.shynixn.mccoroutine.velocity.SuspendingPluginContainer
 import com.velocitypowered.api.plugin.PluginContainer
 import kotlinx.coroutines.Dispatchers
+import kotlinx.coroutines.cancel
 import kotlinx.coroutines.delay
 import kotlinx.coroutines.launch
 import org.apache.logging.log4j.core.Logger
@@ -36,6 +37,8 @@ class MCCoroutineImpl : MCCoroutine {
             plugin
         }
 
+        return items[pluginInstance] ?: throw IllegalArgumentException("Inject SuspendingPluginContainer into your plugin class to boot MCCoroutine!") // surf - access items thread safe
+
         if (!items.containsKey(pluginInstance)) {
             throw IllegalArgumentException("Inject SuspendingPluginContainer into your plugin class to boot MCCoroutine!")
         }
@@ -51,7 +54,7 @@ class MCCoroutineImpl : MCCoroutine {
         pluginContainer: PluginContainer,
         suspendingPluginContainer: SuspendingPluginContainer
     ) {
-        if (items.contains(pluginInstance)) {
+        if (items.containsKey(pluginInstance)) { // surf - use containsKey instead
             return
         }
 
@@ -82,6 +85,13 @@ class MCCoroutineImpl : MCCoroutine {
      * Disables coroutine for the given plugin.
      */
     override fun disable(plugin: PluginContainer) {
+        // surf start - access items thread safe
+        if (true) {
+            val session = items.remove(plugin.instance.get()) ?: return
+            session.dispose()
+            return
+        }
+        // surf end - access items thread safe
         if (!items.containsKey(plugin)) {
             return
         }
