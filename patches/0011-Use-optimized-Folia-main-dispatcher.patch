+package dev.slne.surf.mccoroutine
+
+import kotlinx.coroutines.CoroutineDispatcher
+import kotlinx.coroutines.Runnable
+import org.bukkit.plugin.Plugin
+import java.lang.AutoCloseable
+import java.util.concurrent.RejectedExecutionException
+import java.util.concurrent.atomic.AtomicReference
+import java.util.concurrent.locks.LockSupport
+import java.util.logging.Level
+import kotlin.coroutines.CoroutineContext
+
+class OptimizedMainDispatcher(plugin: Plugin) : CoroutineDispatcher(), AutoCloseable {
+
+    private val logger = plugin.logger
+    private val dispatcherName = "MCCoroutine-${plugin.name}-MainThread"
+
+    private val actionQueue = MpscLinkedQueue<Runnable>()
+
+    @Volatile
+    private var parked = false
+
+    @Volatile
+    private var closed = false
+
+    private val workerThread = Thread(
+        null,
+        ::runEventLoop,
+        dispatcherName,
+        0,
+        false
+    ).apply {
+        isDaemon = true
+    }
+
+    init {
+        workerThread.start()
+    }
+
+    /**
+     * The id of the dedicated dispatcher thread.
+     *
+     * Kept for backwards compatibility with [com.github.shynixn.mccoroutine.folia.CoroutineSession.dispatcherMainThreadId].
+     * Prefer [isDispatcherThread] for thread checks, as it compares the thread reference
+     * directly instead of matching thread ids across threads.
+     */
+    val threadId: Long
+        get() = workerThread.threadId()
+
+    override fun isDispatchNeeded(context: CoroutineContext): Boolean {
+        return Thread.currentThread() !== workerThread
+    }
+
+    /**
+     * Returns true if the calling thread is this dispatcher's dedicated worker thread.
+     */
+    fun isDispatcherThread(): Boolean {
+        return Thread.currentThread() === workerThread
+    }
+
+    override fun dispatch(context: CoroutineContext, block: Runnable) {
+        if (closed) throw rejectedExecution()
+
+        val node = actionQueue.offer(block)
+
+        if (closed) {
+            node.value = null
+            LockSupport.unpark(workerThread)
+            throw rejectedExecution()
+        }
+
+        if (parked) {
+            LockSupport.unpark(workerThread)
+        }
+    }
+
+    private fun runEventLoop() {
+        try {
+            while (!closed) {
+                drainQueue()
+
+                if (closed) break
+                parked = true
+
+                if (closed) {
+                    parked = false
+                    break
+                }
+
+                val racedAction = actionQueue.poll()
+
+                if (racedAction != null) {
+                    parked = false
+                    executeSafely(racedAction)
+                    continue
+                }
+
+                LockSupport.park(this)
+                parked = false
+            }
+        } finally {
+            parked = false
+            closed = true
+
+            actionQueue.clear()
+        }
+    }
+
+    private fun drainQueue() {
+        while (!closed) {
+            val action = actionQueue.poll() ?: return
+            executeSafely(action)
+        }
+    }
+
+    private fun executeSafely(action: Runnable) {
+        try {
+            action.run()
+        } catch (e: Throwable) {
+            @Suppress("removal", "DEPRECATION")
+            when (e) {
+                is ThreadDeath,
+                is VirtualMachineError -> throw e
+
+                else -> logger.log(
+                    Level.SEVERE,
+                    "Unhandled exception in $dispatcherName",
+                    e
+                )
+            }
+        }
+    }
+
+    override fun close() {
+        closed = true
+        LockSupport.unpark(workerThread)
+    }
+
+    fun closeAndJoin() {
+        close()
+
+        if (Thread.currentThread() !== workerThread) {
+            workerThread.join()
+        }
+    }
+
+    private fun rejectedExecution(): RejectedExecutionException {
+        return RejectedExecutionException("$dispatcherName is closed")
+    }
+
+    override fun toString(): String {
+        return dispatcherName
+    }
+
+    private class MpscLinkedQueue<E : Any> {
+
+        class Node<E : Any>(
+            @Volatile
+            var value: E?
+        ) {
+            @Volatile
+            var next: Node<E>? = null
+        }
+
+        private var consumerNode = Node<E>(null)
+        private val producerNode = AtomicReference(consumerNode)
+
+        fun offer(value: E): Node<E> {
+            val node = Node(value)
+            producerNode.getAndSet(node).next = node
+            return node
+        }
+
+        fun poll(): E? {
+            while (true) {
+                val next = consumerNode.next ?: return null
+                consumerNode = next
+
+                val value = next.value
+                next.value = null
+
+                if (value != null) {
+                    return value
+                }
+            }
+        }
+
+        fun clear() {
+            while (poll() != null) {
+                // Clear all elements
+            }
+        }
+    }
+}
