+package dev.slne.surf.mccoroutine
+
+import kotlinx.coroutines.CoroutineDispatcher
+import kotlinx.coroutines.Runnable
+import org.bukkit.plugin.Plugin
+import java.lang.AutoCloseable
+import java.util.concurrent.ConcurrentLinkedQueue
+import java.util.concurrent.Executors
+import java.util.concurrent.RejectedExecutionException
+import java.util.concurrent.atomic.AtomicBoolean
+import kotlin.coroutines.CoroutineContext
+
+class OptimizedMainDispatcher(private val plugin: Plugin): CoroutineDispatcher(), AutoCloseable {
+    private val executor = Executors.newSingleThreadExecutor { r ->
+        Thread(r, "MCCoroutine-${plugin.name}-MainThread")
+    }
+
+    private val actionQueue = ConcurrentLinkedQueue<Runnable>()
+
+    private val drainScheduled = AtomicBoolean(false)
+    private val closed = AtomicBoolean(false)
+
+    @Volatile
+    var threadId = -1L
+        private set
+
+    init {
+        executor.execute {
+            threadId = Thread.currentThread().threadId()
+        }
+    }
+
+    override fun isDispatchNeeded(context: CoroutineContext): Boolean {
+        return Thread.currentThread().threadId() != threadId
+    }
+
+    override fun dispatch(context: CoroutineContext, block: Runnable) {
+        if (closed.get()) return
+
+        if (!isDispatchNeeded(context)) {
+            block.run()
+            return
+        }
+
+        actionQueue.add(block)
+        scheduleDrain()
+    }
+
+    private fun scheduleDrain() {
+        if (!drainScheduled.compareAndSet(false, true)) return
+
+        try {
+            executor.execute {
+                drainQueue()
+            }
+        } catch (_: RejectedExecutionException) {
+            drainScheduled.set(false)
+
+            if (closed.get()) {
+                actionQueue.clear()
+            }
+        }
+    }
+
+    private fun drainQueue() {
+        try {
+            while (!closed.get()) {
+                val action = actionQueue.poll() ?: break
+                action.run()
+            }
+        } finally {
+            drainScheduled.set(false)
+
+            if (!closed.get() && actionQueue.isNotEmpty()) {
+                scheduleDrain()
+            }
+        }
+    }
+
+    override fun close() {
+        if (!closed.compareAndSet(false, true)) {
+            return
+        }
+
+        actionQueue.clear()
+        executor.shutdownNow()
+    }
+}
